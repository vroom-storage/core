{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 31,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default Config",
            "description": "Default configuration using ninja",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "BUILD_TESTS": "ON",
                "BUILD_TOOLS": "ON",
                "ENABLE_CCACHE": "OFF",
                "ENABLE_ASAN": "ON",
                "ENABLE_UBSAN": "ON",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
            }
        },
        {
            "name": "perf",
            "displayName": "Performance measurement config",
            "description": "Configuration for doing performance optimizations",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "BUILD_TESTS": "ON",
                "BUILD_TOOLS": "OFF",
                "ENABLE_CCACHE": "OFF",
                "ENABLE_ASAN": "OFF",
                "ENABLE_UBSAN": "OFF",
                "CMAKE_POLICY_VERSION_MINIMUM": "3.5"
            }
        }
    ]
}
